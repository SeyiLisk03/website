    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <style>
        /* --- VARIABLES & RESET --- */
        :root {
            /* Palette */
            --primary: #0f172a; /* Slate 900 */
            --primary-light: #334155; /* Slate 700 */
            --accent: #d97706; /* Amber 600 */
            --accent-soft: rgba(217, 119, 6, 0.08);
            
            --text-main: #1e293b; /* Slate 800 */
            --text-muted: #64748b; /* Slate 500 */
            --bg-body: #fafafa; /* Neutral 50 */
            --bg-surface: #ffffff;
            
            /* UI Elements */
            --radius-sm: 8px;
            --radius-md: 16px;
            --radius-lg: 24px;
            
            --shadow-subtle: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
            
            --nav-height: 80px;
            --container-width: 1100px; /* Slightly tighter container for reading */
            --transition-smooth: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-main);
            line-height: 1.7;
            background-color: var(--bg-body);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Cormorant Garamond', serif;
            color: var(--primary);
            line-height: 1.1;
            font-weight: 600;
        }

        p {
            margin-bottom: 1.5rem;
        }

        a {
            text-decoration: none;
            color: inherit;
            transition: var(--transition-smooth);
        }

        ul {
            list-style: none;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        .container {
            width: 88%;
            max-width: var(--container-width);
            margin: 0 auto;
        }

        /* --- ANIMATIONS --- */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- BUTTONS --- */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition-smooth);
            border: 1px solid transparent;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
        }

        .btn-primary {
            background-color: var(--primary);
            color: #fff;
        }

        .btn-primary:hover {
            background-color: #000;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        .btn-secondary {
            background-color: transparent;
            border-color: #e2e8f0;
            color: var(--text-main);
        }

        .btn-secondary:hover {
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .btn-text {
            padding: 0;
            color: var(--accent);
            font-weight: 600;
            border-bottom: 1px solid transparent;
            border-radius: 0;
        }
        
        .btn-text:hover {
            border-bottom-color: var(--accent);
        }

        /* --- TYPOGRAPHY UTILS --- */
        .text-overline {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--accent);
            font-weight: 600;
            margin-bottom: 1rem;
            display: block;
        }

        .display-text {
            font-size: 4rem;
            font-weight: 600;
            letter-spacing: -0.03em;
        }

        .section-header {
            text-align: center;
            max-width: 700px;
            margin: 0 auto 5rem;
        }

        .section-header h2 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .section-header p {
            font-size: 1.125rem;
            color: var(--text-muted);
        }

        section {
            padding: 120px 0;
        }

        /* --- NAVIGATION --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px 0;
            z-index: 1000;
            transition: var(--transition-smooth);
        }
        
        header.scrolled {
            background-color: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            padding: 15px 0;
            border-bottom: 1px solid rgba(0,0,0,0.03);
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: -0.01em;
            z-index: 1001;
        }

        .nav-links {
            display: flex;
            gap: 40px;
            align-items: center;
        }

        .nav-links li a {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-main);
            opacity: 0.8;
            position: relative;
        }

        .nav-links li a:hover {
            opacity: 1;
        }

        .nav-cta {
            padding: 10px 24px;
            background-color: var(--primary);
            color: #fff !important;
            border-radius: 50px;
            opacity: 1 !important;
            transition: var(--transition-smooth);
        }
        
        .nav-cta:hover {
            background-color: #000;
            transform: translateY(-1px);
        }

        .hamburger {
            display: none;
            cursor: pointer;
            z-index: 1002;
            font-size: 1.5rem;
        }

        /* --- HERO SECTION --- */
        .hero {
            padding-top: 180px;
            padding-bottom: 100px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            background: radial-gradient(circle at 80% 10%, var(--accent-soft) 0%, transparent 40%);
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 80px;
            align-items: center;
        }

        .hero-text h1 {
            margin-bottom: 1.5rem;
            line-height: 1.05;
        }

        .hero-lead {
            font-size: 1.25rem;
            color: var(--text-muted);
            margin-bottom: 3rem;
            font-weight: 300;
            max-width: 90%;
        }

        .hero-image-container {
            position: relative;
        }

        .hero-img-placeholder {
            aspect-ratio: 0.8;
            background-color: #e2e8f0;
            border-radius: var(--radius-lg);
            border-radius: 200px 200px 20px 20px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-hover);
        }

        .floating-card {
            position: absolute;
            background: white;
            padding: 15px 25px;
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-card);
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.9rem;
            font-weight: 600;
            animation: float 6s ease-in-out infinite;
            z-index: 2;
        }

        .float-1 { bottom: 40px; left: -30px; }
        .float-2 { top: 60px; right: -20px; animation-delay: 2s; }

        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }

        /* --- PHILOSOPHY --- */
        .philosophy-strip {
            padding: 60px 0;
            border-top: 1px solid rgba(0,0,0,0.05);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            background-color: #fff;
        }

        .philosophy-items {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 30px;
            text-align: center;
        }

        .philosophy-item h4 {
            font-size: 1.25rem;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 500;
            color: var(--text-main);
        }
        
        .philosophy-item i {
            color: var(--accent);
            margin-right: 8px;
        }

        /* --- ABOUT --- */
        .about-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;            align-items: start;
        }

        .quote-box {
            padding: 40px;
            background-color: var(--primary);
            color: white;
            border-radius: var(--radius-md);
            position: relative;
            overflow: hidden;
        }

        .quote-box h3 {
            color: white;
            font-size: 2rem;
            font-weight: 400;
            font-style: italic;
            margin-bottom: 20px;
            position: relative;
            z-index: 1;
        }
        
        .quote-box::after {
            content: '"';
            position: absolute;
            bottom: -40px;
            right: 20px;
            font-size: 15rem;
            color: rgba(255,255,255,0.05);
            font-family: serif;
            line-height: 1;
        }

        /* --- SERVICES --- */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
        }

        .service-card {
            background: #fff;
            padding: 40px;
            border-radius: var(--radius-md);
            transition: var(--transition-smooth);
            border: 1px solid rgba(0,0,0,0.03);
            height: 100%;
        }

        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
            border-color: transparent;
        }

        .service-icon {
            font-size: 2rem;
            color: var(--accent);
            margin-bottom: 1.5rem;
            display: inline-block;
        }

        .service-card h3 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            font-family: 'Cormorant Garamond', serif;
        }

        .service-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 0;
        }

        /* --- PROJECTS --- */
        .project-showcase {
            margin-top: 120px;
        }
        
        .project-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
        }

        .project-item {
            group: project;
        }

        .project-img {
            aspect-ratio: 16/10;
            background-color: #e2e8f0;
            border-radius: var(--radius-md);
            margin-bottom: 20px;
            overflow: hidden;
        }
        
        .project-img div {
            width: 100%;
            height: 100%;
            transition: var(--transition-smooth);
            background-size: cover;
            background-position: center;
        }
        
        .project-item:hover .project-img div {
            transform: scale(1.05);
        }

        .project-item h4 {
            font-size: 1.25rem;
            margin-bottom: 0.25rem;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        
        .project-meta {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        /* --- CONTACT --- */
        .contact-section {
            background-color: var(--primary);
            color: white;
            padding: 100px 0;
            border-radius: var(--radius-lg);
            margin-bottom: 40px;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
        }
        
        .contact-content h2 { color: white; margin-bottom: 20px; }
        .contact-content p { color: rgba(255,255,255,0.7); font-size: 1.1rem; }

        .contact-links {
            margin-top: 40px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        
        .contact-link {
            display: flex;
            align-items: center;
            gap: 15px;
            color: white;
            font-size: 1.1rem;
            opacity: 0.9;
        }
        
        .contact-link:hover { opacity: 1; transform: translateX(5px); }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .input-group {
            margin-bottom: 20px;
        }
        
        .input-field {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 16px 20px;
            color: white;
            font-family: inherit;
            border-radius: var(--radius-sm);
            transition: var(--transition-smooth);
        }
        
        .input-field:focus {
            outline: none;
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.3);
        }
        
        .input-field::placeholder { color: rgba(255,255,255,0.3); }

        /* --- FOOTER --- */
        .site-footer {
            padding: 40px 0;
            border-top: 1px solid #e2e8f0;
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        
        .footer-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        /* --- MOBILE --- */
        @media (max-width: 900px) {
            .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 50px; }
            .hero-lead { margin-left: auto; margin-right: auto; }
            .hero-img-placeholder { max-width: 400px; margin: 0 auto; }
            .about-layout { grid-template-columns: 1fr; }
            .contact-grid { grid-template-columns: 1fr; gap: 40px; }
            
            .nav-links {
                position: fixed;
                top: 0;
                right: 0;
                width: 100%;
                height: 100vh;
                background: white;
                flex-direction: column;
                justify-content: center;
                gap: 30px;
                transform: translateX(100%);
                transition: transform 0.4s ease;
                z-index: 999;
            }
            
            .nav-links.active { transform: translateX(0); }
            .nav-links li a { font-size: 1.5rem; font-family: 'Cormorant Garamond', serif; }
            .hamburger { display: block; position: relative; z-index: 1002; }
        }
    </style>
</head>
